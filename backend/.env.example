DATABASE_URL=postgresql://taxapp_user:password@localhost:5432/taxapp_db
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for SSN/sensitive data (32 bytes base64)
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-key

# IRS MeF (direct — on hold until EFIN approved)
# IRS_EFIN=000000
# IRS_MEF_URL=https://la.www4.irs.gov/mef/
# IRS_MEF_TEST_URL=https://la.www4.irs.gov/mef/test/

# TaxBandits (active transmitter)
TAXBANDITS_CLIENT_ID=your-client-id
TAXBANDITS_CLIENT_SECRET=your-client-secret
TAXBANDITS_USER_TOKEN=your-user-token
TAXBANDITS_BASE_URL=https://testapi.taxbandits.com/v1.7.3
TAXBANDITS_AUTH_URL=https://testoauth.expressauth.net/v2/tbsauth

# App
APP_ENV=development
UPLOAD_DIR=/var/taxapp/uploads
ALLOWED_ORIGINS=https://fileextension.taxrefundloan.us,https://taxfiling.taxrefundloan.us,https://loan.taxrefundloan.us,http://localhost:3000
